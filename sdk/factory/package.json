{
  "name": "@fastgpt-plugin/sdk-factory",
  "version": "0.0.1-alpha.1",
  "dependencies": {
    "@fastgpt-plugin/domain": "workspace:*",
    "@fastgpt-plugin/infrastructure": "workspace:*"
  },
  "scripts": {
    "build": "tsdown"
  },
  "devDependencies": {
    "tsdown": "catalog:"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "private": false,
  "publishConfig": {
    "access": "public"
  }
}
